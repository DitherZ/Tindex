# ──── TINDEX ENVIRONMENT CONFIGURATION ──── #
#
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
#
# Required — obtain from https://my.telegram.org/apps
API_ID=
API_HASH=

# Required — the chat/channel ID to index
# Use @userinfobot or similar to find your chat ID
INDEXING_CHAT=

# Required — generate with: python -m tindex.session
SESSION_STRING=

# Optional — server binding
HOST=0.0.0.0
PORT=8080

# Optional — set any value to enable debug logging
# DEBUG=1
